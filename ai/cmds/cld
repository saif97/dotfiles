#!/bin/bash
# default wrapper for Claude Code

unset ANTHROPIC_BASE_URL
unset ANTHROPIC_AUTH_TOKEN
unset API_TIMEOUT_MS

# Auto-enable permissionless mode in VM/SSH environments
if [ -z "$IS_PERSONAL" ] && { [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ] || [ -n "$SSH_CONNECTION" ]; }; then
	set -- "--dangerously-skip-permissions" "$@"
fi

claude "$@"
