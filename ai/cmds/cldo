#!/bin/bash
# OpenRouter AI wrapper for Claude Code

export ANTHROPIC_BASE_URL="https://openrouter.ai/api"
export ANTHROPIC_AUTH_TOKEN="$OPEN_ROUTER_API_KEY"
export ANTHROPIC_API_KEY="" # Important: Must be explicitly empty
export ANTHROPIC_MODEL="moonshotai/kimi-k2.5:fireworks"

# Auto-enable permissionless mode in VM/SSH environments
if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ] || [ -n "$SSH_CONNECTION" ]; then
	set -- "--dangerously-skip-permissions" "$@"
fi

claude "$@"
